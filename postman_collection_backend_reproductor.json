{
  "info": {
    "name": "Backend Reproductor - Iners",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion para probar playlist, player, songs y auth Spotify"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Songs",
      "item": [
        {
          "name": "POST Seed Local MP3",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/songs/seed/local"
          }
        },
        {
          "name": "GET Songs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/songs"
          }
        },
        {
          "name": "GET Search Local",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/songs/search/local?q=remix"
          }
        },
        {
          "name": "GET Search Spotify",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/songs/search/spotify?q=drake"
          }
        },
        {
          "name": "POST Create Song Manual",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Demo Manual\",\n  \"artist\": \"Tester\",\n  \"album\": \"Manual\",\n  \"source\": \"LOCAL\",\n  \"filePathOrUri\": \"music/demo-manual.mp3\"\n}"
            },
            "url": "{{baseUrl}}/api/songs"
          }
        }
      ]
    },
    {
      "name": "Playlist",
      "item": [
        {
          "name": "GET Playlist",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/playlist"
          }
        },
        {
          "name": "POST Add First (songId=1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"songId\": 1\n}"
            },
            "url": "{{baseUrl}}/api/playlist/add/first"
          }
        },
        {
          "name": "POST Add Last (songId=2)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"songId\": 2\n}"
            },
            "url": "{{baseUrl}}/api/playlist/add/last"
          }
        },
        {
          "name": "POST Add At Position 1 (songId=1)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"songId\": 1\n}"
            },
            "url": "{{baseUrl}}/api/playlist/add/at/1"
          }
        },
        {
          "name": "POST Up Next (songId=2)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/playlist/up-next/2"
          }
        },
        {
          "name": "DELETE Song from Playlist (id=1)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/playlist/1"
          }
        }
      ]
    },
    {
      "name": "Player",
      "item": [
        {
          "name": "GET Current",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/player/current"
          }
        },
        {
          "name": "POST Next",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/player/next"
          }
        },
        {
          "name": "POST Previous",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/player/previous"
          }
        },
        {
          "name": "POST Play",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/player/play"
          }
        },
        {
          "name": "POST Pause",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/player/pause"
          }
        },
        {
          "name": "PATCH Repeat NONE",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"NONE\"\n}"
            },
            "url": "{{baseUrl}}/api/player/repeat"
          }
        },
        {
          "name": "PATCH Repeat ONE",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"ONE\"\n}"
            },
            "url": "{{baseUrl}}/api/player/repeat"
          }
        },
        {
          "name": "PATCH Repeat ALL",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mode\": \"ALL\"\n}"
            },
            "url": "{{baseUrl}}/api/player/repeat"
          }
        },
        {
          "name": "GET Stream Song 1",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/player/stream/1"
          }
        }
      ]
    },
    {
      "name": "Spotify Auth",
      "item": [
        {
          "name": "GET Status",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/spotify/status"
          }
        },
        {
          "name": "GET Authorize",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/spotify/authorize"
          }
        },
        {
          "name": "GET Callback (manual code)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/spotify/callback?code=PEGAR_CODE_AQUI"
          }
        },
        {
          "name": "POST Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/spotify/logout"
          }
        }
      ]
    }
  ]
}
